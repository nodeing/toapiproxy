{
  "name": "toapiproxy",
  "version": "0.1.1",
  "description": "AI API proxy desktop app built with Tauri",
  "scripts": {
    "dev": "cargo tauri dev",
    "build": "powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts\\build-app.ps1",
