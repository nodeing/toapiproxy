{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TOAPIPROXY",
  "version": "1.0.0",
  "identifier": "io.toapiproxy.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TOAPIPROXY",
        "width": 1080,
        "height": 650,
        "minWidth": 1080,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "windows/installer-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ]
  }
}
